[sub_resource type="Shader" id="Shader_green_ring"]
code = "shader_type spatial;\nrender_mode unshaded, cull_disabled;\n\n// Green dashed ring: UV.x runs 0..1 around the major circumference.\nuniform vec4 color : source_color = vec4(0.1, 1.0, 0.3, 1.0);\nuniform float dash_count : hint_range(4.0, 32.0) = 12.0;\nuniform float dash_fill : hint_range(0.1, 0.95) = 0.6;\nuniform float glow_strength : hint_range(0.0, 5.0) = 2.0;\n\nvoid fragment() {\n\tfloat t = fract(UV.x * dash_count);\n\tif (t > dash_fill) {\n\t\tdiscard;\n\t}\n\tALBEDO = color.rgb;\n\t// Gentle pulsing glow\n\tEMISSION = color.rgb * glow_strength * (0.7 + 0.3 * sin(TIME * 3.0));\n}\n"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_green_ring"]
shader = SubResource("Shader_green_ring")
shader_parameter/color = Color(0.1, 1.0, 0.35, 1)
shader_parameter/dash_count = 12.0
shader_parameter/dash_fill = 0.6
shader_parameter/glow_strength = 2.0

[sub_resource type="TorusMesh" id="TorusMesh_green_ring"]
material = SubResource("ShaderMaterial_green_ring")
inner_radius = 0.875
outer_radius = 1.125
rings = 64
