[ext_resource type="Script" uid="uid://bgoplane0red1" path="res://Assets/game_over_plane/game_over_plane.gd" id="1_gop01"]

[sub_resource type="Shader" id="Shader_red_dots"]
code = "shader_type spatial;
render_mode unshaded, cull_disabled, blend_mix;

// Red polka-dot pattern: signals danger / out-of-bounds.
uniform vec4 dot_color : source_color = vec4(1.0, 0.05, 0.05, 1.0);
uniform vec4 bg_color   : source_color = vec4(0.08, 0.0, 0.0, 0.65);
uniform float dot_count  : hint_range(2.0, 20.0) = 8.0;
uniform float dot_radius : hint_range(0.05, 0.48) = 0.28;
uniform float glow_strength : hint_range(0.0, 5.0) = 3.0;

void fragment() {
	vec2 grid_uv = fract(UV * dot_count);
	float dist = length(grid_uv - 0.5);
	if (dist < dot_radius) {
		ALBEDO = dot_color.rgb;
		ALPHA  = dot_color.a;
		EMISSION = dot_color.rgb * glow_strength * (0.75 + 0.25 * sin(TIME * 5.0));
	} else {
		ALBEDO = bg_color.rgb;
		ALPHA  = bg_color.a;
	}
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_red_dots"]
render_priority = 0
shader = SubResource("Shader_red_dots")
shader_parameter/dot_color = Color(1, 0.05, 0.05, 1)
shader_parameter/bg_color = Color(0.08, 0, 0, 0.65)
shader_parameter/dot_count = 8.0
shader_parameter/dot_radius = 0.28
shader_parameter/glow_strength = 3.0

